{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theharnessbody.local/schemas/findings.schema.json",
  "title": "Code-review findings",
  "description": "structured findings returned by a code reviewer; designed to live inside the codex envelope (no nested objects or arrays inside array items)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "findings"
  ],
  "properties": {
    "summary": {
      "description": "one-paragraph high-level read of the changes under review",
      "type": "string"
    },
    "findings": {
      "description": "individual review findings",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "file",
          "lines",
          "claim",
          "rationale",
          "suggestion"
        ],
        "properties": {
          "id": {
            "description": "stable identifier for this finding; always present, the harness reconciles new vs resurfaced",
            "type": "string"
          },
          "severity": {
            "description": "does this block the merge",
            "type": "string",
            "enum": [
              "blocker",
              "major",
              "minor"
            ]
          },
          "file": {
            "description": "path to the file the finding concerns, or N/A when no concrete file applies",
            "type": "string"
          },
          "lines": {
            "description": "line or range within the file (for example 42 or 42-58), or N/A",
            "type": "string"
          },
          "claim": {
            "description": "what is wrong or missing",
            "type": "string"
          },
          "rationale": {
            "description": "why the claim matters",
            "type": "string"
          },
          "suggestion": {
            "description": "nullable concrete fix; use null when there is no suggestion",
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          }
        }
      }
    }
  }
}
